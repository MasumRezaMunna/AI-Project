# Base URL of the Express API server
NEXT_PUBLIC_API_URL=http://localhost:4000

# Firebase client config — from the Firebase console: Project settings >
# General > Your apps > (add a Web app if you haven't) > SDK setup and
# configuration > Config. These are safe to expose in the browser (they're
# not secrets — access is controlled by Firebase Auth rules, not by hiding
# these values).
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
